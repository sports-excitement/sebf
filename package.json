{
  "name": "sebf",
  "version": "1.0.0",
  "description": "sports excitement backend framework",
  "main": "server.js",
  "bin": {
    "control": "./control.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --max_old_space_size=4096 server.js",
    "test": "NODE_ENV=test jest --maxWorkers=1",
    "test:watch": "NODE_ENV=test jest --watchAll --maxWorkers=1",
    "test:unit": "NODE_ENV=test jest tests/Unit --maxWorkers=1",
    "test:feature": "NODE_ENV=test jest tests/Feature --maxWorkers=1",
    "test:coverage": "NODE_ENV=test jest --coverage --maxWorkers=1",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:studio": "dotenv -e .env -- prisma studio",
    "prisma:reset": "dotenv -e .env -- prisma migrate reset",
    "prisma:test:generate": "prisma generate --schema=prisma/testing/schema.prisma",
    "prisma:test:push": "prisma db push --schema=prisma/testing/schema.prisma --accept-data-loss",
    "prisma:test:reset": "rm -f prisma/testing/test.db && npm run prisma:test:generate && npm run prisma:test:push",
    "db:seed": "dotenv -e .env -- node database/seeders/UserSeeder.js",
    "db:migrate": "npm run prisma:migrate",
    "db:generate": "npm run prisma:generate",
    "setup": "npm install && npm run db:generate && npm run db:migrate && npm run db:seed",
    "setup:test": "npm run prisma:test:generate && npm run prisma:test:push",
    "control": "node control.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "memory:optimize": "node --max_old_space_size=8192 --optimize_for_size --max_executable_size=8192 --gc_interval=100 server.js"
  },
  "keywords": [
    "express",
    "framework",
    "nodejs",
    "production",
    "robust",
    "supabase",
    "typesense",
    "firebase",
    "minio",
    "redis",
    "sse"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.11.1",
    "@supabase/supabase-js": "^2.50.4",
    "bcryptjs": "^3.0.2",
    "commander": "14.0.0",
    "compression": "^1.8.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "17.2.0",
    "express": "5.1.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.1",
    "express-slow-down": "^2.1.0",
    "express-validator": "^7.2.1",
    "firebase-admin": "^12.7.0",
    "helmet": "8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "sqlite3": "^5.1.7",
    "typesense": "^1.8.2",
    "v8": "^0.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@faker-js/faker": "9.9.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.30.1",
    "jest": "30.0.4",
    "joi": "^17.13.3",
    "nodemon": "^3.1.10",
    "prisma": "6.11.1",
    "supertest": "^7.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
