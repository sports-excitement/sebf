# =============================================================================
# Sports Excitement Core - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="Sports Excitement Core"
APP_VERSION="1.0.0"
APP_ENV=development
APP_KEY=your-generated-app-key-here
APP_DEBUG=true
APP_URL=http://localhost

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Debug and Logging
DEBUG=false
LOG_LEVEL=info
LOG_CHANNEL=stack
# Enable test logging (set to true to see logs during testing)
ENABLE_TEST_LOGGING=false

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT Authentication (REQUIRED)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=sports-excitement-core
JWT_AUDIENCE=sports-excitement-app

# Session Management (REQUIRED)
SESSION_SECRET=your-super-secret-session-key-here
SESSION_NAME=se_session
SESSION_MAX_AGE=86400000
SESSION_SAME_SITE=strict
SESSION_SAVE_UNINITIALIZED=false
SESSION_RESAVE=false

# Health Check API Key (REQUIRED for monitoring)
HEALTH_CHECK_API_KEY=your-health-check-api-key-here

# Health Check Security Configuration
# Security levels: 'public', 'protected', 'private', 'disabled'
HEALTH_CHECK_SECURITY_LEVEL=protected
HEALTH_REQUIRE_API_KEY=false
HEALTH_DISABLE_IN_PRODUCTION=false
HEALTH_PRODUCTION_SAFE_MODE=true

# Advanced Authentication Settings
AUTH_ENFORCE_IP_VALIDATION=false
AUTH_ENFORCE_UA_VALIDATION=false

# Health Check Feature Control
HEALTH_ENABLE_DETAILED=true
HEALTH_ENABLE_SYSTEM_INFO=true
HEALTH_ENABLE_SERVICE_INFO=true
HEALTH_ENABLE_VERSION_INFO=true
HEALTH_ENABLE_INDIVIDUAL_SERVICES=true
HEALTH_ENABLE_LIVENESS=true
HEALTH_ENABLE_READINESS=true
HEALTH_ENABLE_DYNAMIC_SERVICES=true

# Health Check Information Exposure Control
# System info levels: 'none', 'basic', 'detailed'
HEALTH_MAX_SYSTEM_INFO=basic
HEALTH_EXPOSE_PID=false
HEALTH_EXPOSE_MEMORY_DETAILS=false
HEALTH_EXPOSE_PLATFORM=false
HEALTH_EXPOSE_SERVICE_DETAILS=false
HEALTH_EXPOSE_DEPENDENCY_VERSIONS=false

# API Security
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
API_RATE_LIMIT_MESSAGE="Too many requests, please try again later"

# -----------------------------------------------------------------------------
# Service Configuration (Enable/Disable Services)
# -----------------------------------------------------------------------------
# Database (Optional - choose either Prisma/PostgreSQL or MongoDB)
DATABASE_ENABLED=false

# MongoDB (Optional - alternative to Prisma)
MONGODB_ENABLED=false

# Redis (Optional - enabled by default)
REDIS_ENABLED=true

# Typesense Search Engine (Optional)
TYPESENSE_ENABLED=false

# MinIO Object Storage (Optional)
MINIO_ENABLED=false

# Supabase (Optional)
SUPABASE_ENABLED=false

# Firebase (Optional)
FIREBASE_ENABLED=false

# Server-Sent Events (Optional - enabled by default)
SSE_ENABLED=true

# Memory Monitoring (Optional - enabled by default)
MEMORY_ENABLED=true

# Email Service (Optional)
EMAIL_ENABLED=false

# Error Handling Service (Optional - enabled by default)
ERROR_HANDLING_ENABLED=true
ERROR_METRICS_ENABLED=true
ERROR_ALERTING_ENABLED=true
ERROR_RETENTION_PERIOD=86400000
ERROR_LOG_LEVEL=error

# Error Handling Alert Thresholds
ERROR_ALERT_RATE_PER_MINUTE=10
ERROR_ALERT_CRITICAL=1
ERROR_ALERT_CONSECUTIVE=5

# -----------------------------------------------------------------------------
# Database Configuration (Choose ONE: PostgreSQL/Prisma OR MongoDB)
# -----------------------------------------------------------------------------

## PostgreSQL Database (via Prisma) - OPTIONAL
DATABASE_URL="postgresql://user:password@localhost:5432/sports_excitement?schema=public"

# PostgreSQL Connection Settings
DB_CONNECTION=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=sports_excitement
DB_USERNAME=user
DB_PASSWORD=password
DB_SCHEMA=public
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000

## MongoDB Database Configuration - OPTIONAL (Alternative to PostgreSQL)
# Enable MongoDB service
MONGODB_ENABLED=true

# Primary MongoDB Database (Main application data)
MONGODB_PRIMARY_HOST=localhost
MONGODB_PRIMARY_PORT=27017
MONGODB_PRIMARY_DATABASE=sports_excitement_primary
MONGODB_PRIMARY_USERNAME=your_username
MONGODB_PRIMARY_PASSWORD=your_password
MONGODB_PRIMARY_AUTH_SOURCE=admin
MONGODB_PRIMARY_SSL=false
MONGODB_PRIMARY_REPLICA_SET=
MONGODB_PRIMARY_READ_PREFERENCE=primary

# Secondary MongoDB Database (Analytics, logs, separate dataset)
MONGODB_SECONDARY_ENABLED=true
MONGODB_SECONDARY_HOST=localhost
MONGODB_SECONDARY_PORT=27017
MONGODB_SECONDARY_DATABASE=sports_excitement_secondary
MONGODB_SECONDARY_USERNAME=your_username
MONGODB_SECONDARY_PASSWORD=your_password
MONGODB_SECONDARY_AUTH_SOURCE=admin
MONGODB_SECONDARY_SSL=false
MONGODB_SECONDARY_REPLICA_SET=
MONGODB_SECONDARY_READ_PREFERENCE=secondary

# MongoDB Connection Options
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_HEARTBEAT_FREQUENCY=10000
MONGODB_RETRY_WRITES=true
MONGODB_WRITE_CONCERN=majority

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Redis Connection Pool Settings
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=5000
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3
REDIS_FAMILY=4
REDIS_KEY_PREFIX=sports-excitement:

# Redis Fallback
REDIS_FALLBACK_TO_MEMORY=true

# -----------------------------------------------------------------------------
# Typesense Configuration (Search Engine)
# -----------------------------------------------------------------------------
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key

# Typesense Settings
TYPESENSE_CONNECTION_TIMEOUT=5
TYPESENSE_HEALTHCHECK_INTERVAL=30
TYPESENSE_NUM_RETRIES=3
TYPESENSE_RETRY_INTERVAL=0.1
TYPESENSE_LOG_LEVEL=warn

# Typesense Collections
TYPESENSE_USERS_COLLECTION=users
TYPESENSE_LOGS_COLLECTION=system_logs
TYPESENSE_ANALYTICS_COLLECTION=analytics

# -----------------------------------------------------------------------------
# MinIO Configuration (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# MinIO Settings
MINIO_BUCKET=sports-excitement
MINIO_REGION=us-east-1
MINIO_PART_SIZE=64
MINIO_MAX_RETRIES=3
MINIO_RETRY_DELAY=1000
MINIO_PRESIGNED_URL_EXPIRY=3600

# -----------------------------------------------------------------------------
# Supabase Configuration (Alternative Backend)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key

# Supabase Settings
SUPABASE_AUTH_ENABLED=true
SUPABASE_STORAGE_BUCKET=files

# -----------------------------------------------------------------------------
# Firebase Configuration (Notifications & Analytics)
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_KEY=path/to/firebase-service-account-key.json
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Collections
FIREBASE_NOTIFICATIONS_COLLECTION=notifications
FIREBASE_DEVICE_TOKENS_COLLECTION=device_tokens
FIREBASE_ANALYTICS_COLLECTION=analytics
FIREBASE_USER_PROFILES_COLLECTION=user_profiles

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Sports Excitement <noreply@sportsexcitement.com>"

# -----------------------------------------------------------------------------
# Server-Sent Events Configuration
# -----------------------------------------------------------------------------
SSE_HEARTBEAT_INTERVAL=30000
SSE_MAX_CONNECTIONS=1000
SSE_CONNECTION_TIMEOUT=300000
SSE_RETRY_INTERVAL=5000

# -----------------------------------------------------------------------------
# Memory Monitoring Configuration
# -----------------------------------------------------------------------------
MEMORY_MONITORING_ENABLED=true
MEMORY_MONITOR_INTERVAL=60000
MEMORY_THRESHOLD=80

# Advanced Memory Management
MEMORY_WARNING_THRESHOLD=85
MEMORY_CRITICAL_THRESHOLD=95
MAX_MEMORY_THRESHOLD=2048
GC_INTERVAL_MS=300000
HEAP_SNAPSHOT_PATH=./storage/memory-snapshots

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ENABLED=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Alternative name for ALLOWED_ORIGINS (used in some services)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_DESTINATION=uploads/
UPLOAD_PRESERVE_FILENAME=false

# -----------------------------------------------------------------------------
# Development & Testing
# -----------------------------------------------------------------------------
# Enable/disable development features
NODE_ENV=development

# Test Database (for dual database testing)
TEST_DATABASE_URL="file:./prisma/test.db"

# -----------------------------------------------------------------------------
# Production Optimizations
# -----------------------------------------------------------------------------
# Node.js Memory Settings (for production)
NODE_OPTIONS="--max_old_space_size=4096"

# Performance Settings
CLUSTER_WORKERS=auto
ENABLE_COMPRESSION=true
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# External Service URLs (Optional)
# -----------------------------------------------------------------------------
# Webhook URLs
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30000

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=custom

# Monitoring
MONITORING_ENABLED=false
MONITORING_ENDPOINT=https://your-monitoring-service.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_REAL_TIME_NOTIFICATIONS=true
FEATURE_ADVANCED_SEARCH=true
FEATURE_FILE_UPLOADS=true
FEATURE_USER_ANALYTICS=false
FEATURE_ADMIN_PANEL=true

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
CACHE_TTL=3600
CACHE_PREFIX=se_cache:

# -----------------------------------------------------------------------------
# Queue Configuration (Future)
# -----------------------------------------------------------------------------
QUEUE_DRIVER=redis
QUEUE_PREFIX=se_queue:
QUEUE_RETRY_AFTER=90
QUEUE_BLOCK_FOR=null

# -----------------------------------------------------------------------------
# Security Configuration (IP/Access Control)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed IP addresses (optional)
SECURITY_WHITELIST_IPS=
# Comma-separated list of blocked IP addresses (optional)
SECURITY_BLACKLIST_IPS=